open Application;

# Component 001

This is the default component as generated by the ZDragon engine. Feel free to delete this component

component Component001 =
    Name: Component 001
    Description: A default component, we can use these components
        to build up our applications.

component BusinessLogic =
    Name: Business logic Component
    Version: 1.2
    Interactions:
        - Database; Database connection; JDBC
        - PersonHandler


system SystemContainer =
    Version: 0.0.1
    Name: AWS Systems Container
    Description: The main container
    Contains:
        - Component001
        - BusinessLogic
        - GetPerson
        - Foo

endpoint GetPerson :: PersonId -> Person =
    Name: Get Person by Id
    Description: Get a person by the person id.
    Technology: AWS Lambda
    Interactions:
        - Component001
        - BusinessLogic

system Foo =
    Contains:
        - Database
        - PersonHandler

component Database =
    Type: Database

person User001 =
    Name: User 001
    Interactions: 
        - GetPerson


record Person extends Application.Person =
    LastName: String;