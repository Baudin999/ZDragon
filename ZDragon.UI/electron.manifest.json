{
  "executable": "ZDragon.UI",
  "splashscreen": {
    "imageFile": ""
  },
  "name": "ZDragon",
  "author": "Carlos Kelkboom",
  "singleInstance": false,

  "environment": "Production",
  "build": {
    "appId": "com.ZDragon.app",
    "productName": "ZDragon",
    "copyright": "Copyright © 2020",
    "buildVersion": "0.0.1",
    "compression": "maximum",
    "directories": {
      "output": "../../../bin/Desktop"
    },
    "extraResources": [
      {
        "from": "./bin",
        "to": "bin",
        "filter": [ "**/*" ]
      }
    ],
    "files": [
      {
        "from": "./ElectronHostHook/node_modules",
        "to": "ElectronHostHook/node_modules",
        "filter": [ "**/*" ]
      },
      "**/*"
    ]
  }
}